# STELLAR SCREENER — 環境変数テンプレート
# 使い方: このファイルを .env にコピーして値を入力
#   copy .env.template .env
#
# ── ローカル開発 ─────────────────────────────────────────────
#   run_web.bat をダブルクリック、または:
#   venv\Scripts\python.exe -m uvicorn web_app:app --reload --host 127.0.0.1 --port 8000
#
# ── Render 本番（Dashboard → Environment に同じキーを設定）────
#   OPENAI_API_KEY             … 必須（統合AI診断）
#   OPENAI_MODEL               … 任意（デフォルト gpt-4o）
#   OPENAI_BASE_URL            … 任意（デフォルト https://api.openai.com/v1）
#   OPENAI_FALLBACK_BASE_URL   … 任意（Render 等で直通不可時の Cloudflare AI Gateway 等）
#   DB_PATH                    … 任意（デフォルト data/screener.db）
#   DISABLE_SCHEDULER          … 任意（Render 本番は自動無効。GitHub Actions 併用時は 1）

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_FALLBACK_BASE_URL=https://gateway.ai.cloudflare.com/v1/<account_id>/<gateway>/openai
